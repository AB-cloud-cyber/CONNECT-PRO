# ConnectPro - Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
#
# Pour Vercel : utilise "vercel env add" pour chaque variable
# Pour Neon DB : cree une base sur https://neon.tech, copie les identifiants

# Securite
SECRET_KEY=changez-cette-cle-en-production-xK9#mZ2@pL7
FLASK_DEBUG=false

# Base de donnees PostgreSQL (Neon / Supabase / Vercel Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=professionnel_db
DB_USER=flaskuser
DB_PASSWORD=votre_mot_de_passe_fort

# Pour Neon : utiliser l'URI de connexion fournie
# Exemple : postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/professionnel_db?sslmode=require
